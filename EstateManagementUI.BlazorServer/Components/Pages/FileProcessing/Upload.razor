@page "/file-processing/upload"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using EstateManagementUI.BlazorServer.Permissions
@using Microsoft.AspNetCore.Components.Forms
@using EstateManagementUI.BlazorServer.UIServices
@using SimpleResults
@inherits AuthorizedComponentBase
@inject NavigationManager NavigationManager
@inject IFileProcessingUIService FileProcessingUIService
@inject IMerchantUIService MerchantUIService

<PageTitle>Upload File</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Upload File</h1>
            <p class="text-gray-600 mt-1">Select a file profile and CSV file to upload for processing</p>
        </div>
        <button class="btn btn-secondary" @onclick="Cancel">
            Cancel
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg">
            <p class="font-medium">Success</p>
            <p class="text-sm">@successMessage</p>
        </div>
    }

    <div class="bg-white rounded-lg shadow-md p-6">
        <EditForm EditContext="@editContext" OnSubmit="@HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">
                        Merchant <span class="text-red-500">*</span>
                    </label>
                    <InputSelect @bind-Value="model.MerchantId" class="input w-full" name="MerchantId" id="merchantSelect">
                        <option value="">Select a merchant...</option>
                        @foreach (var merchant in merchants)
                        {
                            <option value="@merchant.MerchantId">@merchant.MerchantName</option>
                        }
                    </InputSelect>
                    @if (isLoadingMerchants)
                    {
                        <p class="text-sm text-gray-500 mt-1">Loading merchants...</p>
                    }
                    else if (merchants.Count == 0)
                    {
                        <p class="text-sm text-amber-600 mt-1">No merchants were returned for this estate.</p>
                    }
                    <ValidationMessage For="@(() => model.MerchantId)" class="text-red-600 text-sm mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">
                        File Profile <span class="text-red-500">*</span>
                    </label>
                    <InputSelect @bind-Value="model.FileProfileId" class="input w-full" name="FileProfile" id="fileProfileSelect">
                        <option value="">Select a file profile...</option>
                        @foreach (var fileProfile in fileProfiles)
                        {
                            <option value="@fileProfile.FileProfileId">@fileProfile.Name</option>
                        }
                    </InputSelect>
                    @if (isLoadingFileProfiles)
                    {
                        <p class="text-sm text-gray-500 mt-1">Loading file profiles...</p>
                    }
                    else if (fileProfiles.Count == 0)
                    {
                        <p class="text-sm text-amber-600 mt-1">No file profiles were returned.</p>
                    }
                    <ValidationMessage For="@(() => model.FileProfileId)" class="text-red-600 text-sm mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">
                        CSV File <span class="text-red-500">*</span>
                    </label>
                    <InputFile OnChange="@HandleFileSelected" accept=".csv" class="input w-full" id="uploadFileInput" />
                    @if (selectedFile != null)
                    {
                        <p class="text-sm text-gray-600 mt-2">@selectedFile.Name</p>
                    }
                    @if (!string.IsNullOrWhiteSpace(fileErrorMessage))
                    {
                        <p class="text-red-600 text-sm mt-1">@fileErrorMessage</p>
                    }
                </div>

                <div class="flex justify-end space-x-4 pt-4 border-t">
                    <button type="button" class="btn btn-secondary" @onclick="Cancel">
                        Cancel
                    </button>
                    <button id="uploadFileButton" type="submit" class="btn btn-primary">
                        Upload File
                    </button>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private readonly UploadFileModel model = new();
    private EditContext editContext = default!;
    private string? fileErrorMessage;
    private string? successMessage;
    private IBrowserFile? selectedFile;
    private List<global::EstateManagementUI.BlazorServer.Models.MerchantModels.MerchantDropDownModel> merchants = [];
    private List<global::EstateManagementUI.BlazorServer.Models.FileProfileDropDownModel> fileProfiles = [];
    private const long MaxUploadSizeBytes = 100 * 1024 * 1024;
    private bool isLoadingMerchants = true;
    private bool isLoadingFileProfiles = true;

    protected override void OnInitialized()
    {
        editContext = new EditContext(model);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await OnAfterRender(PermissionSection.FileProcessing, PermissionFunction.Create, LoadDataAsync);
    }

    private void Cancel() => NavigationManager.NavigateTo("/file-processing");

    private async Task<Result> LoadDataAsync()
    {
        isLoadingMerchants = true;
        isLoadingFileProfiles = true;
        Guid estateId = await GetEstateId();
        Result<List<global::EstateManagementUI.BlazorServer.Models.MerchantModels.MerchantDropDownModel>> merchantResult = await MerchantUIService.GetMerchantsForDropDown(global::EstateManagementUI.BusinessLogic.Requests.CorrelationIdHelper.New(), estateId);
        if (merchantResult.IsFailed)
        {
            isLoadingMerchants = false;
            isLoadingFileProfiles = false;
            await InvokeAsync(StateHasChanged);
            return global::Shared.Results.ResultHelpers.CreateFailure(merchantResult);
        }

        Result<List<global::EstateManagementUI.BlazorServer.Models.FileProfileDropDownModel>> fileProfileResult = await FileProcessingUIService.GetFileProfiles();
        if (fileProfileResult.IsFailed)
        {
            isLoadingMerchants = false;
            isLoadingFileProfiles = false;
            await InvokeAsync(StateHasChanged);
            return global::Shared.Results.ResultHelpers.CreateFailure(fileProfileResult);
        }

        merchants = merchantResult.Data;
        fileProfiles = fileProfileResult.Data;

        isLoadingMerchants = false;
        isLoadingFileProfiles = false;
        await InvokeAsync(StateHasChanged);
        return Result.Success();
    }

    private async Task HandleSubmit(EditContext context)
    {
        fileErrorMessage = null;
        successMessage = null;

        var isModelValid = context.Validate();
        if (selectedFile == null)
        {
            fileErrorMessage = "A file is required.";
        }

        if (!isModelValid || selectedFile == null)
        {
            return;
        }

        if (!Guid.TryParse(model.MerchantId, out Guid merchantId))
        {
            fileErrorMessage = "Merchant is required.";
            return;
        }

        Guid estateId = await GetEstateId();
        Guid userId = await GetUserId();

        await using Stream fileStream = selectedFile.OpenReadStream(MaxUploadSizeBytes);
        Result<Guid> uploadResult = await FileProcessingUIService.UploadFileAsync(estateId,
                                                                                   merchantId,
                                                                                   userId,
                                                                                   model.FileProfileId!.Value,
                                                                                   fileStream,
                                                                                   selectedFile.Name);

        if (uploadResult.IsFailed)
        {
            fileErrorMessage = uploadResult.Errors.FirstOrDefault() ?? "The file upload failed.";
            return;
        }

        successMessage = $"File '{selectedFile.Name}' uploaded successfully.";
    }

    private void HandleFileSelected(InputFileChangeEventArgs args)
    {
        selectedFile = args.File;
        fileErrorMessage = null;
        successMessage = null;
    }

    private sealed class UploadFileModel
    {
        [Required(ErrorMessage = "Merchant is required.")]
        public string? MerchantId { get; set; }

        [Required(ErrorMessage = "File profile is required.")]
        public Guid? FileProfileId { get; set; }
    }
}

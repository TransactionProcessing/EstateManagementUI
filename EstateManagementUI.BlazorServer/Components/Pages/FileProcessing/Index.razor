@page "/file-processing"
@using EstateManagementUI.BlazorServer.Models
@using EstateManagementUI.BlazorServer.Permissions
@inject NavigationManager NavigationManager
@inject IPermissionKeyProvider PermissionKeyProvider
@inherits AuthorizedComponentBase

<PageTitle>File Processing</PageTitle>

<div class="space-y-6">
    <div class="flex items-start justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">File Processing</h1>
            <p class="text-sm text-gray-600 mt-1">Review import logs, drill into files, and inspect individual file lines.</p>
        </div>

        <RequirePermission Section="@PermissionSection.FileProcessing" Function="@PermissionFunction.Create" @key="@($"upload-file-{PermissionKeyProvider.GetKey()}")">
            <button class="btn btn-primary" @onclick='() => NavigationManager.NavigateTo("/file-processing/upload")'>
                Upload File
            </button>
        </RequirePermission>
    </div>

    <div class="bg-white rounded-lg shadow-md p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Start date</label>
                <InputDate @bind-Value="startDate" class="input w-full" />
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">End date</label>
                <InputDate @bind-Value="endDate" class="input w-full" />
            </div>
            <div class="flex items-end gap-3">
                <button type="button" class="btn btn-primary" @onclick="ApplyDateFilter">Apply filter</button>
                <button type="button" class="btn btn-secondary" @onclick="ResetDateFilter">Reset</button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="flex items-center justify-center py-12">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
        </div>
    }
    else if (filteredLogs.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-white rounded-lg shadow-md p-6">
                <p class="text-sm text-gray-600 mb-1">Total number of files</p>
                <p class="text-3xl font-bold text-gray-900">@TotalFiles</p>
                <p class="text-xs text-gray-500 mt-2">In the selected date range</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-6">
                <p class="text-sm text-gray-600 mb-1">Total number of file lines</p>
                <p class="text-3xl font-bold text-gray-900">@TotalLines</p>
                <p class="text-xs text-gray-500 mt-2">Across all files in range</p>
            </div>
            <div class="bg-white rounded-lg shadow-md p-6">
                <p class="text-sm text-gray-600 mb-1">Success rate</p>
                <p class="text-3xl font-bold text-green-600">@SuccessRateText</p>
                <p class="text-xs text-gray-500 mt-2">@SuccessfulLines successful / @TotalLines total lines</p>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-md overflow-hidden">
            <table class="table">
                <thead>
                    <tr>
                        <th>ImportLogDate</th>
                        <th>Number of files processed</th>
                        <th class="text-right">Open</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in filteredLogs)
                    {
                        <tr class="hover:bg-gray-50 cursor-pointer" @onclick='() => NavigateToImportLog(log.FileImportLogId)'>
                            <td class="font-medium">@log.ImportLogDate.ToString("dd MMM yyyy")</td>
                            <td>@log.NumberOfFilesProcessed</td>
                            <td class="text-right">
                                <button type="button" class="text-blue-600 hover:text-blue-800 font-medium" @onclick:stopPropagation="true" @onclick='() => NavigateToImportLog(log.FileImportLogId)'>
                                    View details
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="bg-white rounded-lg shadow-md p-6 text-center">
            <p class="text-gray-600">No file import logs found for the selected date range.</p>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private DateTime? startDate;
    private DateTime? endDate;
    private List<FileImportLogDetailsModel> filteredLogs = [];

    protected override async Task OnInitializedAsync()
    {
        await RequirePermission(PermissionSection.FileProcessing, PermissionFunction.List);

        startDate = DateTime.Today.AddDays(-30);
        endDate = DateTime.Today;
        ApplyFilter();
        isLoading = false;
    }

    private int TotalFiles => filteredLogs.Sum(log => log.NumberOfFilesProcessed);
    private int TotalLines => filteredLogs.Sum(log => log.TotalFileLines);
    private int SuccessfulLines => filteredLogs.Sum(log => log.SuccessfulLines);
    private string SuccessRateText => TotalLines == 0 ? "0%" : $"{Math.Round(SuccessfulLines * 100m / TotalLines, 1):0.#}%";

    private void ApplyDateFilter()
    {
        ApplyFilter();
    }

    private void ResetDateFilter()
    {
        startDate = DateTime.Today.AddDays(-30);
        endDate = DateTime.Today;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        filteredLogs = FileProcessingSeedData.FilterByDate(startDate, endDate).ToList();
    }

    private void NavigateToImportLog(Guid fileImportLogId) =>
        NavigationManager.NavigateTo($"/file-processing/{fileImportLogId}");
}

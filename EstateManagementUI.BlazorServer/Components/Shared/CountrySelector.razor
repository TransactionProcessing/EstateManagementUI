@using Microsoft.AspNetCore.Components.Forms
@inherits InputBase<string>

<div class="relative">
    <!-- Dropdown Button -->
    <button type="button" 
            @onclick="ToggleDropdown" 
            class="@CssClass flex items-center justify-between cursor-pointer w-full"
            aria-label="Select country"
            aria-expanded="@isOpen">
        <span class="truncate flex items-center gap-2">
            @if (!string.IsNullOrEmpty(Value))
            {
                var selected = Countries.FirstOrDefault(c => c.Name == Value || c.Code == Value);
                if (selected != null)
                {
                    <span class="text-xl">@selected.Flag</span>
                    <span>@selected.Name</span>
                }
                else
                {
                    <text>@Value</text>
                }
            }
            else
            {
                <text>Select a country...</text>
            }
        </span>
        <svg class="w-4 h-4 ml-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
    </button>

    <!-- Dropdown Menu -->
    @if (isOpen)
    {
        <div class="absolute z-50 mt-1 w-full bg-white border border-gray-300 rounded-md shadow-lg max-h-60 overflow-auto">
            @if (Countries != null && Countries.Any())
            {
                @foreach (var country in Countries)
                {
                    var isSelected = Value == country.Name || Value == country.Code;
                    
                    <button type="button"
                            @onclick="@(() => SelectCountry(country.Name))"
                            class="flex items-center gap-2 px-3 py-2 hover:bg-gray-100 cursor-pointer w-full text-left @(isSelected ? "bg-gray-50" : "")">
                        <span class="text-xl">@country.Flag</span>
                        <span class="text-sm text-gray-700">@country.Name</span>
                    </button>
                }
            }
            else
            {
                <div class="px-3 py-2 text-sm text-gray-500">No countries available</div>
            }
        </div>
    }
</div>

@code {
    private bool isOpen = false;

    private void ToggleDropdown()
    {
        isOpen = !isOpen;
    }

    private void SelectCountry(string countryName)
    {
        CurrentValue = countryName;
        isOpen = false;
    }

    protected override bool TryParseValueFromString(string? value, out string result, out string? validationErrorMessage)
    {
        result = value ?? string.Empty;
        validationErrorMessage = null;
        return true;
    }

